{
  "name": "local-whisper-studio",
  "version": "0.1.4",
  "description": "Secure local speech-to-text desktop app powered by whisper.cpp",
  "main": "./out/main/index.js",
  "author": "Local Whisper Studio",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yauzl": "^3.4.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/yauzl": "^3.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.localwhisper.studio",
    "productName": "Local Whisper Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "THIRD_PARTY_NOTICES.md"
    ],
    "asar": true,
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
