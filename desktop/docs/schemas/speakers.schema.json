{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localwhisperstudio.invalid/schemas/speakers.schema.json",
  "title": "Meeting speakers",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "meetingId", "speakers"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "meetingId": { "type": "string", "pattern": "^mtg_[A-Za-z0-9_-]+$" },
    "speakers": {
      "type": "array",
      "items": { "$ref": "#/$defs/speaker" }
    }
  },
  "$defs": {
    "speaker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "name"],
      "properties": {
        "id": { "type": "string", "pattern": "^(SPEAKER_[0-9]{2,}|UNKNOWN)$" },
        "label": { "type": "string", "minLength": 1 },
        "name": { "type": ["string", "null"] },
        "source": { "enum": ["live", "final", "manual", "imported"] }
      }
    }
  }
}
