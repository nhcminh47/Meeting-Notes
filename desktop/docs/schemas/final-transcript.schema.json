{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localwhisperstudio.invalid/schemas/final-transcript.schema.json",
  "title": "Final transcript",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "meetingId", "language", "generatedAt", "turns"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "meetingId": { "type": "string", "pattern": "^mtg_[A-Za-z0-9_-]+$" },
    "language": { "type": "string", "minLength": 2 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "turns": {
      "type": "array",
      "items": { "$ref": "#/$defs/transcriptTurn" }
    }
  },
  "$defs": {
    "transcriptTurn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "meetingId", "speakerId", "speakerName", "start", "end", "text",
        "language", "source", "isFinal", "confidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "meetingId": { "type": "string", "pattern": "^mtg_[A-Za-z0-9_-]+$" },
        "speakerId": { "type": "string", "pattern": "^(SPEAKER_[0-9]{2,}|UNKNOWN)$" },
        "speakerName": { "type": ["string", "null"] },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "text": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 2 },
        "source": { "enum": ["live", "final", "manual", "imported"] },
        "isFinal": { "const": true },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
