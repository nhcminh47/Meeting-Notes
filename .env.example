# Placeholder values only. Copy to .env for local development; never commit secrets.
ASR_SERVER_URL=https://your-asr-server.example.invalid
ASR_API_KEY=replace-with-a-local-development-key
ASR_TEMP_TTL_SECONDS=3600

# ASR Gateway server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_API_KEY=change-me
SERVER_STORAGE_MODE=ephemeral
ASR_TMP_DIR=/tmp/asr-gateway

DEFAULT_LANGUAGE=en
DEFAULT_LIVE_ENGINE=faster-whisper-live
DEFAULT_LIVE_MODEL=small.en
DEFAULT_FINAL_ENGINE=faster-whisper
DEFAULT_FINAL_MODEL=medium.en

ENABLE_VI=false
ENABLE_LIVE_VI=false

MAX_CONCURRENT_LIVE_SESSIONS=1
MAX_CONCURRENT_JOBS=1

LIVE_AUDIO_BUFFER_SECONDS=30
LIVE_CHUNK_RETENTION_SECONDS=120
LIVE_SESSION_TTL_MINUTES=240
# Explicit test/development backend. Keep false in real deployments.
LIVE_FAKE_ASR=false
# Explicit test/development backend. Never enable as a production substitute.
FINAL_FAKE_ASR=false

# Optional final-transcript diarization. The packaged default is disabled.
ENABLE_FINAL_DIARIZATION=false
DIARIZATION_BACKEND=disabled
DIARIZATION_MODEL=
# Placeholder only. Never commit or log a real model-provider token.
PYANNOTE_AUTH_TOKEN=

JOB_WORKSPACE_TTL_MINUTES=30
COMPLETED_JOB_TTL_MINUTES=10
FAILED_JOB_TTL_MINUTES=30

DELETE_INPUT_AFTER_JOB=true
DELETE_RESULT_AFTER_READ=true

MAX_UPLOAD_MB=1024
MAX_TMP_STORAGE_GB=10
